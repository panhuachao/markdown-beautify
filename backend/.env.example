# 后端环境变量样例
# 复制到 ../.env （项目根目录，docker compose 会读取）

PORT=7001
HOST=0.0.0.0

# 生产务必改为强随机字符串
JWT_SECRET=md-beautify-dev-secret-change-in-prod
JWT_EXPIRES_IN=30d

# 数据库：mysql | sqlite
DB_DRIVER=mysql
# MySQL 配置（与 docker-compose.yml 中的 mysql 服务一致）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=md_beautify
DB_CONNECTION_LIMIT=10
