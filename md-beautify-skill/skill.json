{
  "name": "md-beautify",
  "version": "0.3.0",
  "description": "MD-Beautify · Markdown 一键发布与分享 v0.3（支持用户认证）。将 AI 生成的 Markdown 实时渲染为 Mobile-First 精美网页，返回可分享的短链接。",
  "author": "MD-Beautify Team",
  "license": "MIT",
  "platforms": [
    "openclaw",
    "workbuddy",
    "claude-code",
    "cursor"
  ],
  "entry": "index.js",
  "triggers": [
    "发布到 MD-Beautify",
    "publish to md-beautify",
    "/md-publish",
    "上传 Markdown"
  ],
  "config": {
    "apiBaseUrl": {
      "type": "string",
      "default": "http://localhost:3000",
      "description": "MD-Beautify 后端服务地址"
    },
    "apiKey": {
      "type": "string",
      "default": "",
      "description": "用户 API Key（在 Web 端设置页生成）。也可通过环境变量 MD_BEAUTIFY_API_KEY 传入，优先级更高。"
    }
  },
  "actions": [
    {
      "name": "publish",
      "description": "将 Markdown 内容发布到当前用户的 MD-Beautify 空间",
      "parameters": {
        "content": {
          "type": "string",
          "required": true,
          "description": "Markdown 文本内容"
        },
        "title": {
          "type": "string",
          "required": false,
          "description": "内容标题（不传则自动从 Markdown 第一个 H1 提取）"
        },
        "tags": {
          "type": "array",
          "required": false,
          "description": "标签数组，例如 [\"NLP\", \"2026\"]"
        },
        "apiKey": {
          "type": "string",
          "required": false,
          "description": "临时覆盖 API Key（高级用法）"
        }
      },
      "returns": {
        "success": "boolean",
        "contentId": "string - 内容短标识 slug",
        "url": "string - 移动端优先的分享链接",
        "title": "string - 内容标题",
        "createdAt": "string - ISO 时间戳"
      }
    }
  ]
}
